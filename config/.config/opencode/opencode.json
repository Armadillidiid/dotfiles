{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "instructions": [
    ".github/copilot-instructions.md",
    ".github/instructions/*.md",
    ".agents/*.md",
    "~/.config/opencode/rules/*.md",
    ".opencode/rules/*.md"
  ],
  "permission": {
    "external_directory": {
      "~/ghq/**": "allow",
      "~/.local/share/opencode/**": "allow",
      "~/.config/**": "allow",
      "~/.dotfiles/**": "allow"
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "default"
      }
    }
  },
  "references": {
    "tanstack-form": {
      "path": "~/ghq/github.com/TanStack/form",
      "description": "Use for TanStack Form APIs, types, validation, and field patterns"
    },
    "tanstack-query": {
      "repository": "TanStack/query",
      "description": "Use for TanStack Query hooks, queries, mutations, cache, and SSR patterns"
    },
    "tanstack-table": {
      "path": "~/ghq/github.com/TanStack/table",
      "description": "Use for TanStack Table column definitions, sorting, filtering, and pagination"
    },
    "drizzle-orm": {
      "path": "~/ghq/github.com/drizzle-team/drizzle-orm-docs",
      "description": "Use for Drizzle ORM schema, relations, CRUD queries, and migrations"
    },
    "better-auth": {
      "path": "~/ghq/github.com/better-auth/better-auth",
      "description": "Use for Better Auth server/client API, auth plugins, middleware, and session handling"
    },
    "nextjs": {
      "repository": "vercel/next.js",
      "description": "Use for Next.js App Router, pages router, data fetching, RSC, and API routes",
      "branch": "canary"
    },
    "shadcn-ui": {
      "path": "~/ghq/github.com/shadcn-ui/ui",
      "description": "Use for shadcn/ui component patterns, CLI, registry, and theming conventions"
    },
    "base-ui": {
      "repository": "mui/base-ui",
      "description": "Use for Base UI headless React components, unstyled primitives, and accessible design system building blocks"
    },
    "floci": {
      "path": "~/ghq/github.com/floci-io/floci",
      "description": "Use for floci for emulating AWS services locally similar to LocalStack"
    },
    "calcom": {
      "path": "~/ghq/github.com/calcom/cal.diy"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:P_CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false
    },
    "figma": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "figma-developer-mcp",
        "--figma-api-key={env:P_FIGMA_API_KEY}",
        "--stdio"
      ],
      "enabled": false
    },
    "sentry": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@sentry/mcp-server@latest",
        "--access-token={env:P_SENTRY_API_KEY}"
      ],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--init",
        "--network=host",
        "mcr.microsoft.com/playwright/mcp"
      ],
      "enabled": false
    },
    "aws-diagram": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-diagram-mcp-server"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": false
    },
    "aws": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=us-west-2"
      ],
      "enabled": false
    },
    "void": {
      "type": "local",
      "command": ["pnpm", "dlx", "void", "mcp"],
      "enabled": false
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
    },
  }
}
